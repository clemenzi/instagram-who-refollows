{
  "name": "instagram-who-refollows",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=@instagram-who-refollows/extension",
    "dev:firefox": "turbo run dev:firefox --filter=@instagram-who-refollows/extension",
    "build": "turbo run build",
    "build:firefox": "turbo run build:firefox",
    "zip": "turbo run zip",
    "zip:firefox": "turbo run zip:firefox",
    "compile": "turbo run compile",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "check": "pnpm run compile && pnpm run lint && pnpm run fmt:check",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "lefthook": "^2.1.9",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.68.0",
    "turbo": "^2.10.4"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
