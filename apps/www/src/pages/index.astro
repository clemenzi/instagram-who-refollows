---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Download from "../components/home/Download.astro";
import Faq from "../components/home/Faq.astro";
import Hero from "../components/home/Hero.astro";
import HowItWorks from "../components/home/HowItWorks.astro";
import Privacy from "../components/home/Privacy.astro";
import TrustBar from "../components/home/TrustBar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Who refollows me? — See who doesn't follow you back"
  description="A private browser extension that shows which Instagram accounts don't follow you back. No login, no cloud, no guesswork."
>
  <Header />

  <main id="top">
    <Hero />
    <TrustBar />
    <HowItWorks />
    <Privacy />
    <Faq />
    <Download />
  </main>

  <Footer />
</Layout>
