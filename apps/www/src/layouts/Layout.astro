---
import "../global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "See which Instagram accounts don't follow you back — privately, right in your browser.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fff9ef" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="m-0 min-w-80 overflow-x-clip bg-amber-50 font-sans text-stone-900 antialiased">
    <slot />
  </body>
</html>
