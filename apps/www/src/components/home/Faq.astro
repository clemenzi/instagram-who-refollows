---
const faqs = [
  [
    "Does it need my Instagram password?",
    "No. The extension uses the Instagram session already open in your browser. It never asks for, receives, or stores your password.",
  ],
  [
    "Where does my data go?",
    "Nowhere else. Your follower data is compared locally in the extension and is not uploaded to a developer-controlled server.",
  ],
  [
    "Can I use it for free?",
    "Yes. Who refollows me? is a lightweight, free browser extension with no account to create and no subscription to cancel.",
  ],
] satisfies [string, string][];
---

<section
  id="faq"
  class="mx-auto grid w-full max-w-7xl grid-cols-1 gap-12 px-4 py-24 md:grid-cols-2 md:gap-14 md:px-6 md:py-32 lg:gap-24"
>
  <div class="self-start md:sticky md:top-12">
    <h2 class="font-display text-4xl leading-tight font-bold tracking-tight md:text-6xl">
      A few things<br /><span
        class="bg-linear-to-r from-rose-500 via-fuchsia-500 to-violet-600 bg-clip-text font-display font-normal text-transparent"
        >you might ask first.</span
      >
    </h2>
  </div>
  <div class="border-t border-stone-900/10">
    {
      faqs.map(([question, answer], index) => (
        <details class="group border-b border-stone-900/10 transition" open={index === 0}>
          <summary class="flex cursor-pointer items-center justify-between gap-5 py-6 font-display text-xl font-bold tracking-tight">
            {question}
            <span class="text-2xl font-light group-open:rotate-45">+</span>
          </summary>
          <p class="-mt-1 mb-6 max-w-4xl text-sm leading-7 text-stone-600">{answer}</p>
        </details>
      ))
    }
  </div>
</section>
