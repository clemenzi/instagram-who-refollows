---
import { Download } from "@lucide/astro";
---

<section
  id="download"
  class="relative mx-4 overflow-hidden rounded-3xl bg-linear-to-br from-amber-300 via-rose-400 to-violet-500 px-5 py-20 text-center shadow-2xl shadow-rose-300/40 md:mx-auto md:max-w-7xl md:px-8 md:py-24"
>
  <h2 class="relative font-display text-4xl leading-tight font-bold tracking-tight md:text-6xl">
    Wanna check?<br /><em class="font-display font-normal"
      >Takes one minute.</em
    >
  </h2>
  <p class="relative my-6 text-base text-stone-900">
    Add the extension, open Instagram, and run your first scan.
  </p>
  <a
    class="relative inline-flex min-h-12 w-full items-center justify-center gap-3 rounded-full bg-stone-900 px-6 text-sm font-extrabold text-white shadow-xl transition hover:-translate-y-0.5 md:w-auto"
    href="https://chromewebstore.google.com/detail/who-refollows-me/caiibdnacbgkdknjedbblmmnmhnnpflo"
    ><Download class="size-4" stroke-width={2.2} aria-hidden="true" />Add to
    Chrome free</a
  >
</section>
