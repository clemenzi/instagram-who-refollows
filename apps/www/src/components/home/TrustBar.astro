---
import { LockKeyhole, SearchCheck, ShieldCheck } from "@lucide/astro";
---

<section class="-rotate-1 overflow-hidden bg-stone-900 text-white">
  <div
    class="mx-auto flex w-max items-center gap-7 py-4 text-sm font-extrabold uppercase tracking-widest"
  >
    <span class="inline-flex items-center gap-2"
      ><LockKeyhole
        class="size-4 text-amber-300"
        stroke-width={2.2}
        aria-hidden="true"
      />No password</span
    >
    <span class="inline-flex items-center gap-2"
      ><ShieldCheck
        class="size-4 text-amber-300"
        stroke-width={2.2}
        aria-hidden="true"
      />No upload</span
    >
    <span class="inline-flex items-center gap-2"
      ><SearchCheck
        class="size-4 text-amber-300"
        stroke-width={2.2}
        aria-hidden="true"
      />No guessing</span
    >
  </div>
</section>
