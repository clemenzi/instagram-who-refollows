{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**"]
    },
    "build:firefox": {
      "dependsOn": ["^build:firefox"],
      "outputs": [".output/**"]
    },
    "compile": {
      "dependsOn": ["^compile"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:firefox": {
      "cache": false,
      "persistent": true
    },
    "zip": {
      "dependsOn": ["build"],
      "outputs": [".output/**"]
    },
    "zip:firefox": {
      "dependsOn": ["build:firefox"],
      "outputs": [".output/**"]
    }
  }
}
